# Exchange credentials are stored in the encrypted vault (~/.openmm/vault.enc).
# These env vars are set automatically by the vault loader — you do NOT need
# to set them manually when using `openmm serve`.
#
# MEXC_API_KEY, MEXC_SECRET
# GATEIO_API_KEY, GATEIO_SECRET
# BITGET_API_KEY, BITGET_SECRET, BITGET_PASSPHRASE
# KRAKEN_API_KEY, KRAKEN_SECRET

# Unified IPC socket (default: /tmp/openmm.sock)
# Started by `openmm serve` after interactive vault unlock.
# OPENMM_SOCKET=/tmp/openmm.sock

# Split Execution — payment verification via remote server
PAYMENT_SERVER=https://mcp.openmm.io

# Use testnet chains (Base Sepolia). Default false.
X402_TESTNET=false

# x402 execution mode: local (dev) or facilitator (production)
X402_MODE=local

# Verification mode: basic (fast) or full (cryptographic)
X402_VERIFY_MODE=basic

# Facilitator URL (for X402_MODE=facilitator)
X402_FACILITATOR_URL=https://x402.org
