# MEXC
MEXC_API_KEY=your_mexc_api_key
MEXC_SECRET_KEY=your_mexc_secret_key

# Bitget
BITGET_API_KEY=your_bitget_api_key
BITGET_SECRET=your_bitget_secret
BITGET_PASSPHRASE=your_bitget_passphrase

# Gate.io
GATEIO_API_KEY=your_gateio_api_key
GATEIO_SECRET=your_gateio_secret

# Kraken
KRAKEN_API_KEY=your_kraken_api_key
KRAKEN_SECRET=your_kraken_secret

# Split Execution — Payment via remote server, exchange calls via local keys
# PAYMENT_SERVER: where x402 payment + JWT issuance happens
# WALLET_PRIVATE_KEY: hex private key for signing x402 USDC payments
PAYMENT_SERVER=https://mcp.openmm.io
WALLET_PRIVATE_KEY=0x_your_wallet_private_key

# x402 Payment Configuration (optional - enables pay-per-use for HTTP mode)
# Set these to enable x402 payments for API calls
X402_EVM_ADDRESS=0x_your_base_wallet_address
X402_SOLANA_ADDRESS=your_solana_wallet_address
X402_TESTNET=false

# Execution mode: local (dev) or facilitator (production)
X402_MODE=local

# Verification mode: basic (fast) or full (cryptographic)
X402_VERIFY_MODE=basic

# Facilitator URL (for X402_MODE=facilitator)
X402_FACILITATOR_URL=https://x402.org